NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for metadata/sitemap)
NEXT_PUBLIC_SITE_URL=https://piyamtravels.com

# Mailgun configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_SENDER_EMAIL="Piyam Travel <bookings.noreply@piyamtravel.com>"
TRAVEL_PACKAGES_MAILGUN_SENDER_EMAIL="Piyam Travel <bookings.noreply@piyamtravel.com>"

# MinIO / EU Document Vault (server-side only — do NOT add NEXT_PUBLIC_ prefix)
MINIO_ENDPOINT=https://eu49v2.piyamtravel.com
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=portal-documents
MINIO_PACKAGES_BUCKET_NAME=pt-packages

# MinIO endpoint exposed to the browser (for health checks and display only)
NEXT_PUBLIC_MINIO_ENDPOINT=https://eu49v2.piyamtravel.com

# Travel package backup storage.
# Named R3 inside PT-Portal so it does not conflict with existing document R2_* keys.
R3_ENDPOINT=https://your-package-backup-account.r2.cloudflarestorage.com
R3_PUBLIC_URL=https://your-package-backup-public-domain
R3_ACCESS_KEY_ID=your-package-backup-access-key-id
R3_SECRET_ACCESS_KEY=your-package-backup-secret-access-key
R3_BUCKET_NAME=pt-packages-backup

# Legacy bookings portal migration source.
# Copy values from the old bookings portal Firebase service account.
LEGACY_BOOKINGS_FIREBASE_PROJECT_ID=your-firebase-project-id
LEGACY_BOOKINGS_FIREBASE_CLIENT_EMAIL=your-firebase-client-email
LEGACY_BOOKINGS_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Frappe HRMS integration (server-side only)
FRAPPE_BASE_URL=https://frio.piyamtravel.com
FRAPPE_API_KEY=your-frappe-integration-user-api-key
FRAPPE_API_SECRET=your-frappe-integration-user-api-secret
FRAPPE_WEBHOOK_SECRET=your-shared-frappe-webhook-secret
FRAPPE_HANDOFF_SECRET=your-shared-ims-to-frappe-handoff-secret

# Server Control (server-side only, Super Admin UI)
