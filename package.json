    "bcryptjs": "^3.0.3",
    "form-data": "^4.0.5",
    "html2canvas": "^1.4.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.562.0",
    "mailgun.js": "^12.4.0",
    "next": "^16.1.7",
    "next-nprogress-bar": "^2.4.7",
    "nprogress": "^0.2.0",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
