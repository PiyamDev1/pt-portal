NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for metadata/sitemap)
NEXT_PUBLIC_SITE_URL=https://piyamtravels.com

# Mailgun configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain

# MinIO / EU Document Vault (server-side only — do NOT add NEXT_PUBLIC_ prefix)
MINIO_ENDPOINT=https://eu49v2.piyamtravel.com
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=portal-documents

# MinIO endpoint exposed to the browser (for health checks and display only)
NEXT_PUBLIC_MINIO_ENDPOINT=https://eu49v2.piyamtravel.com
