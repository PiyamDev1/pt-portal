    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.7",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
